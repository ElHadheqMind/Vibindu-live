# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# This file contains example production environment variables
# for Google Cloud Run deployment.
#
# IMPORTANT: These values are set via gcloud commands, NOT via .env files
# This file is for reference only - DO NOT commit actual values!
# ============================================

# ============================================
# AGENTS SERVICE (grafcet-agents)
# ============================================

# Gemini API Key (STORED IN SECRET MANAGER)
# Set via: gcloud secrets create gemini-api-key
# Mounted via: --set-secrets=GEMINI_API_KEY=gemini-api-key:latest
GEMINI_API_KEY=<FROM_SECRET_MANAGER>

# Gemini Model Configuration
GEMINI_MODEL=gemini-3-flash-preview

# Service Port (Cloud Run default)
PORT=8000

# Python Configuration
PYTHONUNBUFFERED=1
PYTHONPATH=/app

# ============================================
# BACKEND SERVICE (grafcet-backend)
# ============================================

# JWT Secret (STORED IN SECRET MANAGER)
# Set via: gcloud secrets create jwt-secret
# Mounted via: --set-secrets=JWT_SECRET=jwt-secret:latest
JWT_SECRET=<FROM_SECRET_MANAGER>

# Google OAuth Client ID (STORED IN SECRET MANAGER)
# Set via: gcloud secrets create google-client-id
# Mounted via: --set-secrets=GOOGLE_CLIENT_ID=google-client-id:latest
GOOGLE_CLIENT_ID=<FROM_SECRET_MANAGER>

# Node Environment
NODE_ENV=production

# Service Port
PORT=3001

# Storage Configuration
STORAGE_DRIVER=local
STORAGE_PATH=/app/data

# Database Configuration
DATABASE_URL=file:/app/data/dev.db

# CORS Configuration (Set to your frontend URL)
# Example: https://grafcet-frontend-xxxxx-uc.a.run.app
CORS_ORIGIN=<FRONTEND_URL>

# ============================================
# FRONTEND SERVICE (grafcet-frontend)
# ============================================

# API Base URL (Set at build time)
# Example: https://grafcet-backend-xxxxx-uc.a.run.app/api
VITE_API_BASE_URL=<BACKEND_URL>/api

# ============================================
# GOOGLE CLOUD CONFIGURATION
# ============================================

# Project Configuration
PROJECT_ID=your-project-id
REGION=us-central1

# Service Account
SERVICE_ACCOUNT=grafcet-app@your-project-id.iam.gserviceaccount.com

# Artifact Registry
ARTIFACT_REGISTRY_REPO=grafcet-repo
ARTIFACT_REGISTRY_URL=us-central1-docker.pkg.dev/your-project-id/grafcet-repo

# ============================================
# CLOUD RUN SERVICE CONFIGURATION
# ============================================

# Resource Limits
# Agents Service
AGENTS_MEMORY=1Gi
AGENTS_CPU=1
AGENTS_MAX_INSTANCES=10
AGENTS_MIN_INSTANCES=0
AGENTS_TIMEOUT=300

# Backend Service
BACKEND_MEMORY=1Gi
BACKEND_CPU=1
BACKEND_MAX_INSTANCES=10
BACKEND_MIN_INSTANCES=0
BACKEND_TIMEOUT=300

# Frontend Service
FRONTEND_MEMORY=512Mi
FRONTEND_CPU=1
FRONTEND_MAX_INSTANCES=10
FRONTEND_MIN_INSTANCES=0

# ============================================
# OPTIONAL: CLOUD SQL CONFIGURATION
# ============================================
# Uncomment if using Cloud SQL instead of SQLite

# Cloud SQL Instance
# CLOUD_SQL_INSTANCE=your-project-id:us-central1:grafcet-db

# Database Connection
# DATABASE_URL=postgresql://user:password@/grafcet?host=/cloudsql/your-project-id:us-central1:grafcet-db

# ============================================
# OPTIONAL: CLOUD STORAGE CONFIGURATION
# ============================================
# Uncomment if using Cloud Storage instead of local storage

# Storage Driver
# STORAGE_DRIVER=gcs

# GCS Bucket
# GCS_BUCKET=your-project-id-grafcet-data

# GCS Configuration
# GCS_PROJECT_ID=your-project-id
# GCS_KEY_FILE=/path/to/service-account-key.json

# ============================================
# MONITORING AND LOGGING
# ============================================

# Log Level
LOG_LEVEL=info

# Enable Debug Mode (set to false in production)
DEBUG=false

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Session Configuration
SESSION_LIFETIME=86400
SESSION_SECURE=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# DEPLOYMENT COMMANDS REFERENCE
# ============================================

# Create Secrets:
# echo -n "YOUR_GEMINI_API_KEY" | gcloud secrets create gemini-api-key --data-file=- --replication-policy="automatic"
# openssl rand -base64 32 | gcloud secrets create jwt-secret --data-file=- --replication-policy="automatic"

# Deploy Agents Service:
# gcloud run deploy grafcet-agents \
#   --image=us-central1-docker.pkg.dev/PROJECT_ID/grafcet-repo/agents:latest \
#   --region=us-central1 \
#   --set-secrets=GEMINI_API_KEY=gemini-api-key:latest \
#   --set-env-vars="PORT=8000,GEMINI_MODEL=gemini-3-flash-preview"

# Deploy Backend Service:
# gcloud run deploy grafcet-backend \
#   --image=us-central1-docker.pkg.dev/PROJECT_ID/grafcet-repo/backend:latest \
#   --region=us-central1 \
#   --set-secrets=JWT_SECRET=jwt-secret:latest \
#   --set-env-vars="PORT=3001,NODE_ENV=production,STORAGE_DRIVER=local"

# Deploy Frontend Service:
# gcloud run deploy grafcet-frontend \
#   --image=us-central1-docker.pkg.dev/PROJECT_ID/grafcet-repo/frontend:latest \
#   --region=us-central1

